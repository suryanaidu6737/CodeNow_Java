import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        long n = sc.nextLong();
        long expectedSum = n * (n + 1) / 2;

        long actualSum = 0;
        for (int i = 0; i < n - 1; i++) {
            long ele=sc.nextLong();
            actualSum+=ele;
        }

        System.out.println(expectedSum - actualSum);
    }
}
