import java.util.*;

class Main{
	public static void main(String args[])
	{
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		int sum=0;
		while(n>0){
			int rem=n%10;
			sum+=rem;
			n/=10;
			if(n==0 && sum>9){
				n=sum;
				sum=0;
			}
		}
		if(sum==1)
		System.out.print(sum);
		else System.out.print("0");
	}
}
