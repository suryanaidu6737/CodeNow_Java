import java.util.*;

class Main{
	public static void main(String args[])
	{
		Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int temp=n,sum=0;
        while(n>0){
            int rem=n%10;
            sum=sum+fact(rem);
            n/=10;
        }
        if(sum==temp) System.out.print('1');
        else System.out.print("0");
	}
    static int fact(int n){
        int f=1;
         for(int i=2;i<=n;i++)
           f*=i;
           return f;
    }
}
