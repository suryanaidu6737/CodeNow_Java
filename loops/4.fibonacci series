import java.util.*;

public class Main{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int fib1=0,fib2=1;
    int fib=0;
    System.out.print(fib1+" "+fib2+" ");
    for(int i=2;i<n;i++){
      fib=fib1+fib2;
      System.out.print(fib+" ");
      fib1=fib2;
      fib2=fib;
    }
  }
}
