import java.util.*;

class Main{
  public static void main(String args[]){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    long fact=1;
    if(n<0){ System.out.println("-1");return;}
    else{
    if(n==0){
      System.out.print("1");return ;
    }
    for(int i=2;i<=n;i++)
      fact*=i;
    }
      System.out.println(fact);

  }
}
