import java.util.*;
class Main{
    public static void main(String arg[]){
        Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        if(n<=1){
            System.out.print("0");
            return;
        }else{
          for(int i=2;i<n;i++){
            if(n%i==0){
              System.out.print("0");
              return;
            }
          }
        }
        System.out.print("1");
    }
}
