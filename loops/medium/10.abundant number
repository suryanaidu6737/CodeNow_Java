import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n1=sc.nextInt();
        int sum1=0;
        for(int i=1;i<n1;i++){
            if(n1%i==0) sum1+=i;
        }
        if(sum1>n1) System.out.println("1");
        else System.out.print("0");
        sc.close();
    }
}
