import java.util.Scanner;
import java.lang.*;
class Main {
    public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      int n=sc.nextInt();
      int rev=0;
      String sign =new String();
      if(n<0)
        sign="-";
      int num=Math.abs(n);
      while(num>0){
        int rem=num%10;
        rev=rev*10+rem;
        num/=10;
      }
      if(n>=0)
      System.out.print(rev);
      else{
        String nn=Integer.toString(rev);
        System.out.print(sign+nn);
      }
    }
}
