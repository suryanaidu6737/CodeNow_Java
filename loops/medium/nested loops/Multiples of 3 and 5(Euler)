import java.util.*;
class Main{
    public static void main(String arg[]){
        Scanner sc = new Scanner(System.in);
        int n=sc.nextInt();
        for(int i=0;i<n;i++){
            int num=sc.nextInt();
            System.out.println(function(num));
        }
    }
    static int function(int n)
    {
        int sum=0;
        for(int i=3;i<n;i++){
            if(i%3==0 || i%5==0) sum+=i;
        }
        return sum;
    }
}
