import java.util.*;
class Main{
    public static void main(String arg[]){
        Scanner sc = new Scanner(System.in);
         int n=sc.nextInt();
         int sum=0;
         for(int i=1;i<n;i++){
            if(n%i==0) sum+=i;
         }
         if(sum==n) System.out.print("True");
         else System.out.print("False");
    }
}
