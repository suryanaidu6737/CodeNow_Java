import java.io.*;
import java.util.*;

public class Main {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int s=sc.nextInt();
        int diff=sc.nextInt();
        int inc=sc.nextInt();
        int n=sc.nextInt();
        int count=1;
        while(count<n){
            s=s+diff;
            diff+=inc;
            count++;
        }
        System.out.print(s);
    }
}
