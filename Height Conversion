import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        double cm = sc.nextDouble();

        double inches = cm / 2.54;
        double feet = inches / 12;

        System.out.printf("%.2f\n", inches);
        System.out.printf("%.2f", feet);

        sc.close();
    }
}
